{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Advisor Mode Verification Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "correlationKey",
    "commands",
    "changed_files",
    "residual_risks",
    "created_at"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "verification-evidence"
    },
    "correlationKey": {
      "type": "string",
      "minLength": 1
    },
    "verdict_ref": {
      "type": "string",
      "minLength": 1
    },
    "executor_decision_ref": {
      "type": "string",
      "minLength": 1
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "purpose",
          "command",
          "exit_status",
          "summary",
          "timestamp"
        ],
        "properties": {
          "purpose": {
            "type": "string",
            "enum": [
              "test",
              "typecheck",
              "lint",
              "smoke",
              "assertion",
              "manual-check-summary"
            ]
          },
          "command": {
            "type": "string",
            "minLength": 1
          },
          "exit_status": {
            "oneOf": [
              { "type": "number" },
              { "type": "string", "minLength": 1 }
            ]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "timestamp": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "residual_risks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
